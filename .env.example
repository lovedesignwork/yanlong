# =============================================================================
# YAN LONG MAISON — Environment Variables
# Copy this file to `.env.local` and fill in your real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Email (Resend) — for the reservation form
# Get an API key at https://resend.com (free tier: 3,000 emails/month)
# Until you add a verified domain in Resend, the FROM address must be
# `onboarding@resend.dev`. After verifying yanlongphuket.com, change to
# `reservations@yanlongphuket.com`.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where reservations get emailed (comma-separated for multiple recipients)
# Both inboxes receive every reservation request.
RESERVATION_TO=yanlong@royalphuketcity.com,marketing@royalphuketcity.com

# Where reservation emails appear to come from
RESERVATION_FROM="Yan Long Reservations <onboarding@resend.dev>"

# Optional: BCC a copy to a backup inbox (comma-separated)
# RESERVATION_BCC=

# -----------------------------------------------------------------------------
# Supabase — shared Royal Phuket City Hotel database
# All reservations and contact messages are written here so the RPCH admin
# dashboard can manage them. Values come from the RPCH project.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://crhzxvbubvyachauomlx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
